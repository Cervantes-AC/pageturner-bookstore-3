APP_NAME=PageTurner Bookstore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pageturner
DB_USERNAME=root
DB_PASSWORD=

# ── Read Replica Configuration (Section 4.5) ──
# Configure these when read replicas are available.
DB_READ_HOST_1=127.0.0.1
DB_READ_HOST_2=127.0.0.1
DB_WRITE_HOST=127.0.0.1
DB_STICKY=true

# ── Cache / Session / Queue ──
CACHE_DRIVER=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Redis Configuration ──
# Database 0: General purpose
# Database 1: Query result caching
# Database 2: Session storage
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Scout Search ──
# Options: database, meilisearch, algolia, typesense
SCOUT_DRIVER=database
SCOUT_QUEUE_CONNECTION=redis
SCOUT_QUEUE=scout

# ── Meilisearch (optional) ──
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# ── Algolia (optional) ──
ALGOLIA_APP_ID=
ALGOLIA_SECRET=

# ── Mail ──
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your_gmail@gmail.com"
MAIL_FROM_NAME="PageTurner Bookstore"
MAIL_VERIFY_PEER=false
MAIL_VERIFY_PEER_NAME=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
